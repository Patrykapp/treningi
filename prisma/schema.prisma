// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String            @id @default(cuid())
  name            String
  email           String?           @unique
  passwordHash    String?
  sessions        WorkoutSession[]
  bodyWeights     BodyWeight[]
  favorites       UserFavorite[]
  templates       WorkoutTemplate[]
  runs            RunSession[]
  otherActivities OtherActivity[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Exercise {
  id           String         @id @default(cuid())
  name         String         @unique
  muscleGroup  String?
  exerciseDbId String?
  // Media z ExerciseDB V2 (RapidAPI) — cache w bazie, żeby runtime nie odpytywał
  // API (limity darmowego planu). Uzupełniane przez prisma/link-v2-media.ts.
  v2Id         String?        // ID ćwiczenia w V2 (exr_...)
  v2ImageUrl   String?        // statyczny obraz (miniatura / poster)
  v2VideoUrl   String?        // animowane wideo (MP4) — odtwarzane jak GIF
  v2Checked    Boolean        @default(false) // już próbowano dopasować (także gdy brak trafienia)
  entries      WorkoutEntry[]
  favorites    UserFavorite[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model WorkoutSession {
  id          String         @id @default(cuid())
  date        DateTime
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  notes       String?
  entries     WorkoutEntry[]
  activities  OtherActivity[] // inne aktywności przypięte do tego treningu (ten sam dzień)
  runs        RunSession[] // biegi przypięte do tego treningu (ten sam dzień, np. bieg + challenge)
  // Dane z zegarka (import TCX) — opcjonalne
  durationSec Int?
  kcal        Int?
  avgHr       Int?
  maxHr       Int?
  hrSeries    Json           @default("[]") // śr. tętno per 30 s
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId, date])
}

model WorkoutEntry {
  id         String         @id @default(cuid())
  sessionId  String
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])
  sets       Int
  reps       Int
  weight     Float
  rpe        Float?
  comment    String?
  setsData   Json           @default("[]")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([sessionId])
  @@index([exerciseId])
}

model BodyWeight {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  weight    Float
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model UserFavorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, exerciseId])
}

model WorkoutTemplate {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  entries   Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RunSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  distance  Float    // km
  duration  Int      // seconds
  splits    Json     @default("[]") // array of seconds per km segment
  notes     String?
  // Dane z zegarka (import TCX) — opcjonalne
  kcal      Int?
  avgHr     Int?
  maxHr     Int?
  // Opcjonalne przypięcie do treningu z tego samego dnia (np. bieg + challenge)
  sessionId String?
  session   WorkoutSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([sessionId])
}

model OtherActivity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  type        String   // "Rower", "Pływanie", "Kajak" itp.
  durationMin Int      // czas w minutach
  distanceKm  Float?   // opcjonalnie
  kcal        Int?     // opcjonalnie
  notes       String?
  // Opcjonalne przypięcie do treningu z tego samego dnia
  sessionId   String?
  session     WorkoutSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, date])
  @@index([sessionId])
}
