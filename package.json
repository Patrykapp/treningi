{
  "name": "workout-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx ts-node --project tsconfig.scripts.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:exercises": "npx ts-node --project tsconfig.scripts.json prisma/add-exercises.ts",
    "db:rename": "npx ts-node --project tsconfig.scripts.json prisma/rename-exercises.ts",
    "db:exercises-full": "npx ts-node --project tsconfig.scripts.json prisma/exercises-full.ts",
    "db:create-user": "npx ts-node --project tsconfig.scripts.json prisma/create-user.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.0.0",
    "jose": "^5.10.0",
    "next": "16.2.6",
    "papaparse": "^5.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^6.0.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
